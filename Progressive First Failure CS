# ==============================================================================
# --- PROGRESSIVE FIRST FAILURE CENSORING MLE INFERENCE ---
# ==============================================================================
libs <- c("GA", "DEoptim", "metaheuristicOpt", "pso", "numDeriv", "MASS")
new_libs <- libs[!(libs %in% installed.packages()[,"Package"])]
if(length(new_libs)) install.packages(new_libs)
invisible(lapply(libs, library, character.only = TRUE))

#' Maximum Likelihood Estimation under Progressive First-Failure Censoring
#'
#' @description `pffcs` computes the Maximum Likelihood Estimates (MLE), variances,
#' standard errors, and asymptotic 95\% confidence intervals for the parameters
#' of any user-defined lifetime distribution under a Progressive First-Failure
#' Censoring scheme.
#'
#' @param x_obs A numeric vector containing the completely observed failure times.
#' @param R A numeric vector specifying the progressive censoring scheme (number of groups removed at each failure time).
#' @param par_start A numeric vector of initial parameter values in standard space (transformed internally to log-space).
#' @param pdf_f A user-defined function for the probability density function (PDF). Must accept arguments \code{(x, par)}.
#' @param cdf_f A user-defined function for the cumulative distribution function (CDF). Must accept arguments \code{(x, par)}.
#' @param opt_method A character string specifying the optimization algorithm. Default is \code{"auto"} to evaluate all available engines.
#' @param maxiter An integer specifying the maximum number of iterations for metaheuristic search engines. Default is 200.
#'
#' @details The function handles bounded parameter spaces by optimizing in log-space,
#' automatically enforcing positivity constraints. When \code{opt_method = "auto"},
#' it evaluates standard gradient-based methods alongside an array of global
#' metaheuristic algorithms (GA, DE, PSO, GWO, WOA, MFO, SCA, BA, BHO) to bypass
#' local extrema before conducting a final BFGS polish.
#'
#' @return A named list containing three main components:
#' \item{estimates}{A data frame with parameter names, MLE estimates, variances, standard errors, 95\% asymptotic confidence intervals, and fit statistics.}
#' \item{stats}{A named numeric vector tracking the maximized Log-Likelihood, AIC, and BIC values.}
#' \item{selected_optimizer}{A character string returning the name of the optimization routine that achieved the absolute lowest negative log-likelihood.}
#'
#' @references
#' Aarset, M. V. (1987). How to identify a bathtub hazard rate. \emph{IEEE Transactions on Reliability}, 36(1), 106-108.
#'
#' Murthy, D. P., Xie, M., & Jiang, R. (2004). \emph{Weibull models}. John Wiley & Sons.
#'
#' @importFrom GA ga
#' @importFrom DEoptim DEoptim DEoptim.control
#' @importFrom pso psoptim
#' @importFrom metaheuristicOpt GWO WOA MFO SCA BA BHO metaOpt
#' @importFrom MASS ginv
#' @importFrom stats optim
#'
#' @return A list containing estimates, stats, and the best optimizer.
#' @export
pffcs <- function(x_obs, R, par_start, pdf_f, cdf_f, opt_method = "auto", maxiter = 200) {

  # ============================================================================
  # INPUT CHECKS
  # ============================================================================

  if(!is.numeric(x_obs) || length(x_obs) == 0)
    stop("ERROR: 'x_obs' must be a non-empty numeric vector.")

  if(!is.numeric(par_start) || length(par_start) == 0)
    stop("ERROR: 'par_start' must be a non-empty numeric vector.")

  if(!is.function(pdf_f))
    stop("ERROR: 'pdf_f' must be a function.")

  if(!is.function(cdf_f))
    stop("ERROR: 'cdf_f' must be a function.")

  if(!is.numeric(R) || length(R) != length(x_obs) || any(R < 0) || any(R != floor(R)))
    stop("ERROR: 'R' must be a non-negative integer vector of the same length as 'x_obs'.")

  if(sum(R) >= length(x_obs))
    stop("ERROR: sum(R) must be less than the total number of observations.")

  if(any(x_obs <= 0))
    warning("WARNING: Data contains zero or negative values. This may cause issues for some distributions.")

  if(length(x_obs) < 10)
    warning("WARNING: Sample size is very small (n < 10). Estimates may not be reliable.")

  if(length(par_start) == 1)
    warning("WARNING: Single parameter distribution detected. Please verify 'par_start' is correct.")

  # ============================================================================

  k <- length(par_start)
  eps <- 1e-12
  lb <- rep(-10, k)
  ub <- rep(10, k)

  # --- Negative Progressive First Failure Log-Likelihood ---
  nll <- function(par) {
    theta <- par
    f <- pmax(pdf_f(x_obs, theta), eps)
    S <- pmax(1 - cdf_f(x_obs, theta), eps)

    ll <- sum(log(f)) + sum(R * log(S))

    if (!is.finite(ll)) return(1e12)
    return(-ll)
  }

  # --- Optimization Runner ---
  run_opt <- function(method) {
    tryCatch({
      sol <- if (method %in% c("BFGS", "Nelder-Mead")) log(par_start) else {
        switch(method,
               GA  = GA::ga("real-valued", function(p) -nll(p), lb, ub,
                            maxiter = maxiter, monitor = FALSE)@solution[1,],
               DE  = DEoptim::DEoptim(nll, lb, ub,
                                      DEoptim::DEoptim.control(trace = FALSE, itermax = maxiter))$optim$bestmem,
               PSO = pso::psoptim(log(par_start), nll, lower = lb, upper = ub,
                                  control = list(maxit = maxiter))$par,
               GWO = metaheuristicOpt::GWO(nll, k, lb, ub, max_iter = maxiter)$Best_P,
               WOA = metaheuristicOpt::WOA(nll, k, lb, ub, max_iter = maxiter)$Best_P,
               MFO = metaheuristicOpt::MFO(nll, k, lb, ub, max_iter = maxiter)$Best_P,
               SCA = metaheuristicOpt::SCA(nll, k, lb, ub, max_iter = maxiter)$Best_P,
               BA  = metaheuristicOpt::BA(nll, k, lb, ub, max_iter = maxiter)$Best_P,
               BHO = metaheuristicOpt::BHO(nll, k, lb, ub, max_iter = maxiter)$Best_P,
               metaheuristicOpt::metaOpt(nll, k, lb, ub, algorithm = method, max_iter = maxiter)$Best_P
        )
      }

      if (k == 1) stats::optim(sol, nll, method = "Brent", lower = lb[1], upper = ub[1], hessian = TRUE)
      else        stats::optim(sol, nll, method = "BFGS", hessian = TRUE)

    }, error = function(e) NULL)
  }

  # --- Decision Logic ---
  methods_to_try <- if (opt_method == "auto")
    c("BFGS", "GA", "DE", "PSO", "GWO", "WOA", "MFO", "SCA", "BA", "BHO", "COA", "CLG")
  else opt_method

  best_res    = list(value = Inf)
  all_results <- list()

  for (m in methods_to_try) {
    res <- run_opt(m)

    if (!is.null(res) && is.finite(res$value)) {
      all_results[[m]] <- data.frame(
        Method = m,
        NLL    = round(res$value, 6),
        stringsAsFactors = FALSE
      )
    }

    if (!is.null(res) && is.finite(res$value) && res$value < best_res$value) {
      best_res <- res
      best_res$method <- m
    }
  }

  if (best_res$value == Inf) stop("Optimization failed across all methods.")

  # --- Comparison Table ---
  if (opt_method == "auto" && length(all_results) > 0) {
    comparison <- do.call(rbind, all_results)
    comparison <- comparison[order(comparison$NLL), ]
    rownames(comparison) <- NULL
    cat("\n========================================\n")
    cat("    ALL METHODS COMPARISON\n")
    cat("========================================\n")
    print(comparison)
    cat("----------------------------------------\n")
    cat(">>> Best method:", best_res$method, "| NLL:", round(best_res$value, 6), "\n")
    cat("========================================\n\n")
  }

  # --- Result Formatting ---
  vcov_matrix <- tryCatch(
    solve(best_res$hessian),
    error = function(e) {
      warning("WARNING: Hessian could not be inverted, using Moore-Penrose pseudoinverse. Standard errors may be approximate.")
      MASS::ginv(best_res$hessian)
    }
  )

  se <- sqrt(abs(diag(vcov_matrix)))

  if(any(se > 10))
    warning("WARNING: Some standard errors are very large. Estimates may not be reliable. Consider updating 'par_start'.")

  # İstatistiksel değerleri önceden hesapla
  calc_loglik <- -best_res$value
  calc_aic    <- 2 * k + 2 * best_res$value
  calc_bic    <- k * log(length(x_obs)) + 2 * best_res$value

  return(list(
    estimates = data.frame(
      Estimate  = best_res$par,
      Variance  = se^2,
      StdError  = se,
      CI_Lower  = best_res$par - 1.96 * se,
      CI_Upper  = best_res$par + 1.96 * se,
      Optimizer = best_res$method,
      LogLik    = calc_loglik,  # LogLik sütunu eklendi
      stringsAsFactors = FALSE
    ),
    stats = c(
      LogLik = calc_loglik,
      AIC    = calc_aic,
      BIC    = calc_bic
    ),
    optimizer = best_res$method
  ))
}

# ==============================================================================
# --- USER SECTION ---
# ==============================================================================

# 1. Real Data Application using Aarset (1987) lifetime data
data <- c(0.040, 1.866, 2.385, 3.443, 0.301, 1.876, 2.481, 3.467, 0.309, 1.899,
          2.610, 3.478, 0.557, 1.911, 2.625, 3.578, 0.943, 1.912, 2.632, 3.595,
          1.070, 1.914, 2.646, 3.699, 1.124, 1.981, 2.661, 3.779, 1.248, 2.010,
          2.688, 3.924, 1.281, 2.038, 2.823, 4.035, 1.281, 2.085, 2.890, 4.121,
          1.303, 2.089, 2.902, 4.167, 1.432, 2.097, 2.934, 4.240, 1.480, 2.135,
          2.962, 4.255, 1.505, 2.154, 2.964, 4.278, 1.506, 2.190, 3.000, 4.305,
          1.568, 2.194, 3.103, 4.376, 1.615, 2.223, 3.114, 4.449, 1.619, 2.224,
          3.117, 4.485, 1.652, 2.229, 3.166, 4.570, 1.652, 2.300, 3.344, 4.602,
          1.757, 2.324, 3.376, 4.663)

# 2. Set up a mathematically valid scheme where sum(R) < length(x_obs)
scheme <- c(8, rep(0, 11)) # Example scheme matching m = 12 failures
sorted_data <- sort(data)
obs_data <- sorted_data[1:12]

# 3. User Defined Distribution Functions (PDF & CDF Formulas)
user_pdf <- function(x, par) {
  (par[2]/par[1]) * (x/par[1])^(par[2]-1) * exp(-(x/par[1])^par[2])
}

user_cdf <- function(x, par) {
  1 - exp(-(x/par[1])^par[2])
}

# 4. Analysis Execution
res <- pffcs(x_obs = obs_data,
             R = scheme,
             par_start = c(2, 2),
             pdf_f = user_pdf,
             cdf_f = user_cdf,
             opt_method = "auto") # Set to "auto" to see comparison and automatic selection

# Print Results
print(res$estimates)
